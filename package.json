{
  "name": "confluence-to-notion",
  "version": "0.1.2",
  "description": "Auto-discover Confluence → Notion transformation rules using a multi-agent pipeline",
  "license": "MIT",
  "type": "module",
  "private": false,
  "bin": {
    "c2n": "dist/cli.js",
    "c2n-mcp": "dist/mcp.js"
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "eval:pipeline": "pnpm exec c2n eval output/ eval_results/ samples/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@notionhq/client": "5.20.0",
    "@xmldom/xmldom": "^0.9.10",
    "commander": "^12.1.0",
    "undici": "7.25.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.17.9",
    "@vitest/coverage-v8": "^2.1.8",
    "msw": "2.13.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/let-sunny/confluence-to-notion.git"
  },
  "bugs": {
    "url": "https://github.com/let-sunny/confluence-to-notion/issues"
  },
  "homepage": "https://github.com/let-sunny/confluence-to-notion#readme",
  "keywords": ["confluence", "notion", "migration", "wiki", "converter"]
}
