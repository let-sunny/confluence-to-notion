# Confluence settings
# For public wikis (e.g., cwiki.apache.org), only CONFLUENCE_BASE_URL is required.
# For private/Cloud wikis, also set EMAIL and API_TOKEN.
CONFLUENCE_BASE_URL=https://cwiki.apache.org/confluence
# CONFLUENCE_EMAIL=your-email@example.com
# CONFLUENCE_API_TOKEN=your-confluence-api-token
# Override for self-hosted Confluence (default: /rest/api)
# CONFLUENCE_API_PATH=/rest/api

# Notion integration token
NOTION_API_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx
NOTION_ROOT_PAGE_ID=your-notion-page-id
